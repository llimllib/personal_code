{
  "enabled": true,
  "network": {
    "allowedDomains": [
      "amazonaws.com",
      "*.amazonaws.com",
      "api.github.com",
      "github.com",
      "localhost",
      "nodejs.org",
      "raw.githubusercontent.com"
    ],
    "deniedDomains": [],
    "allowUnixSockets": ["/tmp/*"],
    "allowLocalBinding": true
  },
  "filesystem": {
    "denyRead": ["~/.gnupg", "~/.ssh"],
    "allowWrite": [".", "/tmp", "~/Library/Logs", "~/.cache", "../main"],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "mise.toml",
      "mise.local.toml"
    ]
  }
}
