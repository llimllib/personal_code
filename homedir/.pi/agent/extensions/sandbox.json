{
  "enabled": true,
  "//": "This allows go to access the trustd daemon that it uses to verify certificates: https://github.com/anthropic-experimental/sandbox-runtime/pull/120",
  "enableWeakerNetworkIsolation": true,
  "network": {
    "allowedDomains": [
      "amazonaws.com",
      "*.amazonaws.com",
      "*.atlassian.net",
      "crates.io",
      "*.crates.io",
      "*.en.dev",
      "api.github.com",
      "github.com",
      "raw.githubusercontent.com",
      "golang.org",
      "*.golang.org",
      "storage.googleapis.com",
      "*.hashicorp.com",
      "linear.app",
      "*.linear.app",
      "localhost",
      "nodejs.org",
      "*.nodejs.org",
      "npmjs.org",
      "*.npmjs.org",
      "pypi.org",
      "files.pythonhosted.org",
      "*.rust-lang.org",
      "rust-lang.org",
      "*.slack.com",
      "slack.com",
      "*.youtube.com",
      "youtube.com"
    ],
    "deniedDomains": [],
    "allowUnixSockets": ["/tmp", "/private/tmp"],
    "allowLocalBinding": true
  },
  "filesystem": {
    "denyRead": ["~/.gnupg", "~/.ssh"],
    "allowWrite": [
      ".",
      "../main",
      "/tmp",
      "/private/tmp",
      "/var/folders",
      "~/.cache",
      "~/.local",
      "~/.npm",
      "~/.rustup",
      "~/go",
      "~/Library/Logs",
      "~/Library/Caches"
    ],
    "denyWrite": [
      ".env",
      ".env.*",
      "*.pem",
      "*.key",
      "mise.toml",
      "mise.local.toml",
      "*.tfstate",
      "*.tfstate.backup",
      "**/.terraform/**",
      "**/terraform.tfstate",
      "**/terraform.tfstate.backup"
    ]
  }
}
